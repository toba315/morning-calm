{
  "name": "morning-calm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backlog:sync": "node scripts/backlog-sync.mjs sync",
    "backlog:task": "node scripts/backlog-sync.mjs task",
    "serve": "node scripts/static-server.mjs",
